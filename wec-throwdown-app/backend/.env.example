# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/wec_throwdown

# JWT Secret - CHANGE THIS IN PRODUCTION!
# Generate a strong random string: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=wec-throwdown-development-secret-key-change-in-production

# Environment
NODE_ENV=development

# Server Port
PORT=5000

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
